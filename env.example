# ============================================================================
# SurgiPredict Pro - Environment Configuration
# ============================================================================
# COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES
# DO NOT COMMIT THIS FILE TO GITHUB - Add .env.local to .gitignore
# ============================================================================

# ============================================================================
# REQUIRED - ANTHROPIC API CONFIGURATION
# ============================================================================

# Your Anthropic API Key - Get from https://console.anthropic.com/account/keys
# Example: sk-ant-v0-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REACT_APP_ANTHROPIC_API_KEY=sk-ant-

# Anthropic API Endpoint (usually doesn't need to change)
REACT_APP_ANTHROPIC_API_URL=https://api.anthropic.com/v1

# Model to use (latest recommended)
REACT_APP_MODEL_VERSION=claude-sonnet-4-20250514

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment: development, staging, or production
REACT_APP_ENV=development

# Log level: debug, info, warn, error
REACT_APP_LOG_LEVEL=info

# Enable debug mode
REACT_APP_DEBUG=false

# ============================================================================
# IMAGE PROCESSING CONFIGURATION
# ============================================================================

# Maximum file size in bytes (10MB default)
REACT_APP_MAX_FILE_SIZE=10485760

# Supported image formats
REACT_APP_SUPPORTED_FORMATS=jpg,png,jpeg,webp,heic

# Image compression quality (0-100)
REACT_APP_IMAGE_QUALITY=85

# Resize images to max width (pixels)
REACT_APP_IMAGE_MAX_WIDTH=1024

# ============================================================================
# DATABASE CONFIGURATION (OPTIONAL - for patient data persistence)
# ============================================================================

# Supabase Configuration (PostgreSQL)
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# Firebase Configuration (Alternative to Supabase)
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_STORAGE_BUCKET=

# MongoDB Configuration (Alternative)
REACT_APP_MONGODB_URI=

# ============================================================================
# CLOUD STORAGE CONFIGURATION (OPTIONAL - for image storage)
# ============================================================================

# AWS S3
REACT_APP_AWS_REGION=us-east-1
REACT_APP_AWS_ACCESS_KEY_ID=
REACT_APP_AWS_SECRET_ACCESS_KEY=
REACT_APP_AWS_S3_BUCKET=

# Google Cloud Storage
REACT_APP_GCS_BUCKET=
REACT_APP_GCS_API_KEY=

# Azure Blob Storage
REACT_APP_AZURE_STORAGE_ACCOUNT=
REACT_APP_AZURE_STORAGE_KEY=
REACT_APP_AZURE_CONTAINER_NAME=

# ============================================================================
# MONITORING & ANALYTICS (OPTIONAL)
# ============================================================================

# Sentry Error Tracking
REACT_APP_SENTRY_DSN=
REACT_APP_SENTRY_ENVIRONMENT=development

# Google Analytics
REACT_APP_GA_MEASUREMENT_ID=

# Amplitude Analytics
REACT_APP_AMPLITUDE_API_KEY=

# ============================================================================
# BACKEND SERVER CONFIGURATION (if running Node.js backend)
# ============================================================================

# Backend API URL
REACT_APP_API_URL=http://localhost:5000
REACT_APP_API_TIMEOUT=30000

# Backend port (if running locally)
PORT=5000

# Enable CORS
REACT_APP_ENABLE_CORS=true

# ============================================================================
# MEDICAL COMPLIANCE (OPTIONAL - if serving healthcare industry)
# ============================================================================

# HIPAA Compliance Mode
REACT_APP_HIPAA_MODE=false

# GDPR Compliance Mode
REACT_APP_GDPR_MODE=false

# Data encryption enabled
REACT_APP_ENABLE_ENCRYPTION=false

# Audit logging enabled
REACT_APP_AUDIT_LOG=false

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable 3D visualization
REACT_APP_ENABLE_3D=true

# Enable AI recommendations
REACT_APP_ENABLE_AI=true

# Enable report generation
REACT_APP_ENABLE_REPORTS=true

# Enable image upload
REACT_APP_ENABLE_IMAGE_UPLOAD=true

# Enable patient database
REACT_APP_ENABLE_DATABASE=false

# Enable payment/billing
REACT_APP_ENABLE_PAYMENTS=false

# ============================================================================
# PAYMENT CONFIGURATION (OPTIONAL - for premium features)
# ============================================================================

# Stripe Configuration
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_
REACT_APP_STRIPE_SECRET_KEY=sk_test_

# Paddle Configuration
REACT_APP_PADDLE_VENDOR_ID=
REACT_APP_PADDLE_API_KEY=

# ============================================================================
# EMAIL CONFIGURATION (OPTIONAL - for sending reports)
# ============================================================================

# SendGrid
REACT_APP_SENDGRID_API_KEY=

# Mailgun
REACT_APP_MAILGUN_DOMAIN=
REACT_APP_MAILGUN_API_KEY=

# SMTP
REACT_APP_SMTP_HOST=
REACT_APP_SMTP_PORT=587
REACT_APP_SMTP_USER=
REACT_APP_SMTP_PASSWORD=

# ============================================================================
# UI/UX CONFIGURATION
# ============================================================================

# Primary brand color
REACT_APP_BRAND_COLOR=#d4af37

# Dark mode enabled by default
REACT_APP_DARK_MODE=true

# Animations enabled
REACT_APP_ENABLE_ANIMATIONS=true

# ============================================================================
# SECURITY
# ============================================================================

# JWT Secret (if using authentication)
REACT_APP_JWT_SECRET=

# Session timeout (minutes)
REACT_APP_SESSION_TIMEOUT=60

# Enable rate limiting
REACT_APP_ENABLE_RATE_LIMITING=true

# Rate limit: requests per minute
REACT_APP_RATE_LIMIT_RPM=50

# ============================================================================
# DEVELOPMENT TOOLS
# ============================================================================

# Show debug console
REACT_APP_SHOW_DEBUG_CONSOLE=false

# Enable React DevTools
REACT_APP_ENABLE_DEVTOOLS=true

# Enable Redux DevTools
REACT_APP_ENABLE_REDUX_DEVTOOLS=false

# ============================================================================
# ADVANCED CONFIGURATION
# ============================================================================

# Custom API endpoint
REACT_APP_CUSTOM_API_ENDPOINT=

# Custom theme file
REACT_APP_THEME_FILE=

# Content Security Policy enabled
REACT_APP_ENABLE_CSP=true

# Subresource Integrity enabled
REACT_APP_ENABLE_SRI=true

# ============================================================================
# NOTES
# ============================================================================
# 
# 1. REQUIRED VALUES:
#    Only REACT_APP_ANTHROPIC_API_KEY is strictly required
#    
# 2. LOCAL DEVELOPMENT:
#    Copy this file to .env.local and fill in only what you need
#    
# 3. PRODUCTION:
#    Configure in your deployment platform:
#    - Vercel: Settings → Environment Variables
#    - AWS: Systems Manager → Parameter Store
#    - Docker: docker run -e VAR=value
#    
# 4. SECURITY:
#    Never commit real API keys
#    Rotate keys regularly
#    Use different keys for dev/staging/production
#    
# 5. GET HELP:
#    Documentation: See IMPLEMENTATION_GUIDE.md
#    API Keys: https://console.anthropic.com
#    Support: Check QUICK_START.md
#
# ============================================================================
